  = re.sub(r'[^\w_]', '', h)     return h.lower()  def
  try_parse_date(val: str) -> Optional[str]:     if pd.isna(val):
  return None     s = str(val).strip()     if s == '':         return
  None     # Common non-date markers     if re.fullmatch(r'[-/.]+',
  s):         return None     try:         dt = dateparser.parse(s,
